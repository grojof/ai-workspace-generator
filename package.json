{
  "name": "ai-workspace-generator",
  "version": "0.1.1",
  "description": "Generate and adapt an AI workspace (Claude Code + GitHub Copilot) for any project: layered instructions, skills, SDD, MCPs, living docs and token-efficient config.",
  "type": "module",
  "bin": {
    "ai-workspace": "dist/cli.js",
    "ai-workspace-generator": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "skill-packs"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "pretest": "tsc -p tsconfig.json",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage",
    "release": "node scripts/release.mjs"
  },
  "keywords": [
    "ai",
    "claude-code",
    "copilot",
    "agents",
    "agents-md",
    "scaffold",
    "generator",
    "sdd",
    "mcp",
    "context7"
  ],
  "author": "Guillermo Rojo <guillermo.rojo.fdez@gmail.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/grojof/ai-workspace-generator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grojof/ai-workspace-generator.git"
  },
  "bugs": {
    "url": "https://github.com/grojof/ai-workspace-generator/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "commander": "^15.0.0",
    "eta": "^4.6.0",
    "picocolors": "^1.1.0",
    "yaml": "^2.5.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
